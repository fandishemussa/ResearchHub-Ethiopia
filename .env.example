# ResearchHub Ethiopia environment template.

RESEARCHHUB_APP_NAME=ResearchHub Ethiopia
RESEARCHHUB_APP_ENV=local
RESEARCHHUB_LOG_LEVEL=INFO
RESEARCHHUB_API_PREFIX=/api

RESEARCHHUB_DATABASE_URL=postgresql+asyncpg://researchhub:researchhub@postgres:5432/researchhub
RESEARCHHUB_SYNC_DATABASE_URL=postgresql+psycopg://researchhub:researchhub@postgres:5432/researchhub
RESEARCHHUB_REDIS_URL=redis://redis:6379/0

# API capacity and graceful lifecycle
RESEARCHHUB_API_WORKERS=1
RESEARCHHUB_API_GRACEFUL_TIMEOUT_SECONDS=30
RESEARCHHUB_API_KEEPALIVE_SECONDS=5
RESEARCHHUB_API_MAX_CONCURRENT_REQUESTS=500
RESEARCHHUB_SLOW_REQUEST_THRESHOLD_MS=1000
RESEARCHHUB_MAX_REQUEST_BODY_MB=10

# Keep the combined capacity of every API and worker below PostgreSQL max_connections.
RESEARCHHUB_DB_POOL_SIZE=5
RESEARCHHUB_DB_MAX_OVERFLOW=5
RESEARCHHUB_DB_POOL_TIMEOUT_SECONDS=10
RESEARCHHUB_DB_POOL_RECYCLE_SECONDS=1800
RESEARCHHUB_DB_POOL_PRE_PING=true
RESEARCHHUB_DB_STATEMENT_TIMEOUT_MS=30000
RESEARCHHUB_DB_LOCK_TIMEOUT_MS=5000
RESEARCHHUB_DB_IDLE_TRANSACTION_TIMEOUT_MS=60000
RESEARCHHUB_DB_USE_PGBOUNCER=false

RESEARCHHUB_REDIS_MAX_CONNECTIONS=100
RESEARCHHUB_REDIS_SOCKET_CONNECT_TIMEOUT=2
RESEARCHHUB_REDIS_SOCKET_TIMEOUT=2
RESEARCHHUB_REDIS_HEALTH_CHECK_INTERVAL=30
RESEARCHHUB_REDIS_RETRY_ON_TIMEOUT=true
RESEARCHHUB_REDIS_CACHE_DEFAULT_TTL=300

RESEARCHHUB_HTTP_CONNECT_TIMEOUT_SECONDS=5
RESEARCHHUB_HTTP_READ_TIMEOUT_SECONDS=30
RESEARCHHUB_HTTP_WRITE_TIMEOUT_SECONDS=30
RESEARCHHUB_HTTP_MAX_CONNECTIONS=100
RESEARCHHUB_HTTP_MAX_KEEPALIVE_CONNECTIONS=20

RESEARCHHUB_ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8111"]
RESEARCHHUB_CONNECTOR_USER_AGENT=ResearchHubEthiopia/0.1 (+https://researchhub.local)
RESEARCHHUB_CONNECTOR_TIMEOUT_SECONDS=30
RESEARCHHUB_CONNECTOR_MAX_RETRIES=4
RESEARCHHUB_CONNECTOR_RATE_LIMIT_PER_SECOND=2
RESEARCHHUB_HARVEST_CONFIG_PATH=harvester/config/harvest_connectors.example.json
RESEARCHHUB_METADATA_QUALITY_WEIGHTS={"completeness":0.30,"validity":0.20,"consistency":0.15,"uniqueness":0.15,"timeliness":0.10,"accessibility":0.10}
RESEARCHHUB_METADATA_QUALITY_CHECK_URL_REACHABILITY=false
RESEARCHHUB_METADATA_QUALITY_URL_TIMEOUT_SECONDS=3

RESEARCHHUB_OPENALEX_MAILTO=research-office@example.edu.et
RESEARCHHUB_CROSSREF_MAILTO=research-office@example.edu.et
RESEARCHHUB_OPENAI_BASE_URL=http://ollama:11434/v1
RESEARCHHUB_OPENAI_API_KEY=local-ollama
RESEARCHHUB_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RESEARCHHUB_EMBEDDING_DEVICE=cpu
RESEARCHHUB_EMBEDDING_DIMENSION=384

# Local-first AI research intelligence. Never commit real API keys.
RESEARCHHUB_AI_PROVIDER=local
RESEARCHHUB_AI_CHAT_PROVIDER=local
RESEARCHHUB_AI_SUMMARY_PROVIDER=local
RESEARCHHUB_AI_EMBEDDING_PROVIDER=local
RESEARCHHUB_AI_CHAT_MODEL=grounded-local-v1
RESEARCHHUB_AI_SUMMARY_MODEL=grounded-extractive-v1
RESEARCHHUB_AI_REQUEST_TIMEOUT=120
RESEARCHHUB_AI_MAX_RETRIES=3
RESEARCHHUB_AI_MAX_CONTEXT_PUBLICATIONS=8
RESEARCHHUB_AI_MAX_MESSAGE_CHARS=4000
RESEARCHHUB_AI_DEFAULT_TEMPERATURE=0.1
RESEARCHHUB_AI_EMBEDDING_BATCH_SIZE=32
RESEARCHHUB_AI_EMBEDDING_NORMALIZE=true
RESEARCHHUB_AI_CHAT_MAX_CONTEXT_TOKENS=8000
RESEARCHHUB_AI_CHAT_RETRIEVAL_LIMIT=20
RESEARCHHUB_AI_ENABLE_OPENAI=false
RESEARCHHUB_AI_ENABLE_OLLAMA=false
RESEARCHHUB_OLLAMA_BASE_URL=http://ollama:11434
RESEARCHHUB_KEYWORD_EXTRACTION_METHOD=hybrid
RESEARCHHUB_KEYWORD_MAX_KEYWORDS=12
RESEARCHHUB_KEYWORD_MIN_CONFIDENCE=0.25
RESEARCHHUB_DUPLICATE_MINIMUM_SCORE=0.70
RESEARCHHUB_DUPLICATE_HIGH_CONFIDENCE_SCORE=0.85
RESEARCHHUB_DUPLICATE_VERY_HIGH_CONFIDENCE_SCORE=0.95
RESEARCHHUB_SEMANTIC_SEARCH_MINIMUM_SCORE=0.60
RESEARCHHUB_SEMANTIC_SEARCH_WEIGHT=0.50
RESEARCHHUB_LEXICAL_SEARCH_WEIGHT=0.25
RESEARCHHUB_TREND_MINIMUM_PUBLICATIONS=3
RESEARCHHUB_TREND_CACHE_TTL_SECONDS=3600
RESEARCHHUB_HARVEST_BATCH_SIZE=500
RESEARCHHUB_HARVEST_REQUEST_TIMEOUT_SECONDS=60
RESEARCHHUB_HARVEST_MAX_RETRIES=3
RESEARCHHUB_HARVEST_RETRY_BACKOFF_SECONDS=5
RESEARCHHUB_HARVEST_MAX_CONCURRENT_PER_SOURCE=1
RESEARCHHUB_MAX_ACTIVE_HARVESTS_GLOBAL=8
RESEARCHHUB_MAX_ACTIVE_IMPORTS_GLOBAL=4
RESEARCHHUB_MAX_ACTIVE_AI_GENERATIONS_PER_USER=2
RESEARCHHUB_MAX_ACTIVE_CHAT_STREAMS_PER_USER=2
RESEARCHHUB_MAX_ACTIVE_CHAT_STREAMS_GLOBAL=50
RESEARCHHUB_MAX_ACTIVE_DOCUMENT_JOBS=4
RESEARCHHUB_MAX_SEARCH_PAGE_SIZE=100
RESEARCHHUB_MAX_BATCH_OPERATION_SIZE=1000
RESEARCHHUB_IMPORT_MAX_FILE_SIZE_MB=100
RESEARCHHUB_IMPORT_STORAGE_PATH=/app/data/imports
RESEARCHHUB_IMPORT_PREVIEW_LIMIT=20
RESEARCHHUB_AUTH_JWT_SECRET=replace-with-at-least-32-random-characters
RESEARCHHUB_AUTH_JWT_ALGORITHM=HS256
RESEARCHHUB_AUTH_JWT_ISSUER=researchhub-ethiopia
RESEARCHHUB_AUTH_JWT_AUDIENCE=researchhub-api
RESEARCHHUB_AUTH_ACCESS_TOKEN_MINUTES=15
RESEARCHHUB_AUTH_REFRESH_TOKEN_DAYS=30
RESEARCHHUB_AUTH_CLOCK_SKEW_SECONDS=30
RESEARCHHUB_AUTH_MAX_FAILED_ATTEMPTS=5
RESEARCHHUB_AUTH_LOCKOUT_MINUTES=15
RESEARCHHUB_AUTH_RESET_TOKEN_MINUTES=30

RESEARCHHUB_CELERY_TASK_SOFT_TIME_LIMIT=900
RESEARCHHUB_CELERY_TASK_TIME_LIMIT=960
RESEARCHHUB_CELERY_WORKER_PREFETCH_MULTIPLIER=1
RESEARCHHUB_METRICS_ENABLED=true
RESEARCHHUB_METRICS_PATH=/metrics
RESEARCHHUB_LOAD_TEST_MODE=false

# Browser-to-Next.js API timeout (milliseconds)
NEXT_PUBLIC_API_TIMEOUT_MS=30000
# Chat retrieval and local model generation may take longer than normal API requests.
NEXT_PUBLIC_AI_TIMEOUT_MS=210000
